{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "description": "Group all Ansible Galaxy updates into a single PR",
      "matchManagers": ["ansible-galaxy"],
      "groupName": "Ansible dependencies"
    },
    {
      "description": "Group all GitHub Actions updates into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Label Docker-related PRs",
      "matchManagers": ["dockerfile", "docker-compose"],
      "labels": ["docker", "dependencies"]
    },
    {
      "description": "Label Python PRs",
      "matchManagers": ["pip_requirements", "pep621"],
      "labels": ["python", "dependencies"]
    },
    {
      "description": "Auto-merge patch updates for Python packages",
      "matchManagers": ["pip_requirements", "pep621"],
      "matchUpdateTypes": ["patch"]
    }
  ]
}