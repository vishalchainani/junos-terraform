#!/usr/bin/env python3
import argparse
import copy
import json
import os
import re
import shutil
import yaml
from xml.etree import ElementTree
from typing import Any, Optional


_OMIT = object()


def prepare_tag(tag: str) -> str:
    """Prepare XML tag to be used as YAML key by replacing '-' and '.' with '_'."""
    return tag.replace("-", "_").replace(".", "_")


def detect_device_type(xml_dict: dict[str, Any]) -> Optional[str]:
    """Detect device type from configuration (e.g., 'qfx', 'srx', 'mx').

    Looks for device model or version hints in system/product-name or chassis.
    """
    # Check system.product_name
    if "system" in xml_dict and isinstance(xml_dict["system"], dict):
        product_name = xml_dict["system"].get("product_name", "").lower()
        if product_name:
            # Extract device type from product name (e.g., "Juniper Networks QFX5100" -> "qfx")
            for device_type in ["qfx", "srx", "mx", "ptx", "acx", "ex"]:
                if device_type in product_name:
                    return device_type

    # Check chassis.product_name
    if "chassis" in xml_dict and isinstance(xml_dict["chassis"], dict):
        product_name = xml_dict["chassis"].get("product_name", "").lower()
        if product_name:
            for device_type in ["qfx", "srx", "mx", "ptx", "acx", "ex"]:
                if device_type in product_name:
                    return device_type

    return None


def element_node(
    element: ElementTree.Element,
    path: str,
    resources: dict[str, Any],
):
    """Return the resource node matching the given XML element and path.

    Args:
        element: XML element to match.
        path: Path to match in the schema.
        resources: Schema resource node to search.

    Returns:
        The matching resource node or None if not found.
    """

    if resources["name"] == element.tag and (
        resources.get("path") is None or (resources["path"] + "/" + element.tag) == path
    ):
        return {k: v for k, v in resources.items() if k != "children"}

    try:
        for elem in resources["children"]:
            matched_type = element_node(element, path, elem)
            if matched_type:
                return matched_type
    except KeyError:
        return None

    return None


def elem_to_dict(
    element: ElementTree.Element,
    path: str,
    resources: Any,
) -> dict[str, Any]:
    """Convert an XML element and its children to a dictionary.

    Args:
        element: XML element to convert.
        path: Current path of the element. Needed to uniquely identify the
            element in the schema.
        resources: Schema resource node to use for type information.

    Returns:
        A dictionary representation of the XML element.
    """

    result = {}
    for child in element:
        prepared_tag = prepare_tag(child.tag)
        prepared_path = child.tag
        if len(path) > 0:
            prepared_path = path + "/" + child.tag
        resource_node = element_node(child, prepared_path, resources)
        elem_type = resource_node["type"] if resource_node else None

        if elem_type == "list":
            # If the element is of type list, always create a list
            if not result.get(prepared_tag):
                result[prepared_tag] = []
            if len(child) > 0:
                result[prepared_tag].append(
                    elem_to_dict(child, prepared_path, resources)
                )
            else:
                result[prepared_tag].append(child.text)
        elif elem_type == "leaf-list":
            # If the element is of type leaf-list, always create a list
            result[prepared_tag] = child.text
        elif elem_type == "container":
            # If the element is of type container, always create a dict
            if len(child) > 0:
                result[prepared_tag] = elem_to_dict(child, prepared_path, resources)
            else:
                result[prepared_tag] = ""
        else:
            # For other types, decide based on children
            if len(child) > 0:
                result[prepared_tag] = elem_to_dict(child, prepared_path, resources)
            else:
                if elem_type == "leaf":
                    if not child.text:
                        result[prepared_tag] = True
                    else:
                        result[prepared_tag] = child.text
                else:
                    result[prepared_tag] = child.text
    return result


ALL_YAML = "all.yaml"
HOST_PAYLOAD_CACHE_FILE = ".jtaf_host_payloads.json"


def _plain_group_name(name: str) -> str:
    """Return plain group name from an internal token."""
    if ":" in name:
        return name.split(":", 1)[1]
    return name


def _is_scalar(value: Any) -> bool:
    return not isinstance(value, (dict, list))


def _value_key(value: Any) -> str:
    try:
        return json.dumps(value, sort_keys=True)
    except TypeError:
        return str(value)


def _infer_identity_key_for_dict_lists(
    dict_lists: list[list[dict[str, Any]]],
) -> Optional[str]:
    """Infer a stable identity key shared across list-of-dict payloads."""
    non_empty = [lst for lst in dict_lists if lst]
    if not non_empty:
        return None

    common_keys = set(non_empty[0][0].keys())
    for lst in non_empty:
        for item in lst:
            if not isinstance(item, dict):
                return None
            common_keys &= set(item.keys())

    preferred = ["name", "id", "key", "uuid"]
    ordered = [key for key in preferred if key in common_keys]
    ordered.extend(sorted(key for key in common_keys if key not in preferred))

    for candidate in ordered:
        valid = True
        for lst in non_empty:
            seen: set[str] = set()
            for item in lst:
                if candidate not in item:
                    valid = False
                    break
                key_val = item[candidate]
                if key_val is None or not _is_scalar(key_val):
                    valid = False
                    break
                token = _value_key(key_val)
                if token in seen:
                    valid = False
                    break
                seen.add(token)
            if not valid:
                break

        if valid:
            return candidate

    return None


def _as_keyed_list_map(
    items: list[dict[str, Any]],
    key_name: str,
) -> tuple[dict[str, dict[str, Any]], list[str]]:
    """Convert list-of-dicts into token map and stable token order."""
    mapping: dict[str, dict[str, Any]] = {}
    order: list[str] = []

    for item in items:
        token = _value_key(item[key_name])
        mapping[token] = item
        order.append(token)

    return mapping, order


def intersect_values(left: Any, right: Any):
    """Return shared structure/value between two objects.

    Dicts are intersected recursively by key. Lists/scalars are shared only
    when exactly equal, except keyed list-of-dicts which are intersected by key.
    """
    if type(left) is not type(right):
        return _OMIT

    if isinstance(left, dict):
        common = {}
        for key in left.keys() & right.keys():
            shared_value = intersect_values(left[key], right[key])
            if shared_value is not _OMIT:
                common[key] = shared_value
        return common

    if isinstance(left, list):
        if left == right:
            return copy.deepcopy(left)

        if left and right and all(isinstance(item, dict) for item in left + right):
            key_name = _infer_identity_key_for_dict_lists([
                [item for item in left if isinstance(item, dict)],
                [item for item in right if isinstance(item, dict)],
            ])
            if key_name:
                left_map, left_order = _as_keyed_list_map(left, key_name)
                right_map, _ = _as_keyed_list_map(right, key_name)
                shared_items: list[dict[str, Any]] = []
                for token in left_order:
                    if token not in right_map:
                        continue
                    shared_value = intersect_values(left_map[token], right_map[token])
                    if isinstance(shared_value, dict) and shared_value:
                        shared_items.append(shared_value)
                return shared_items if shared_items else _OMIT

        return _OMIT

    return copy.deepcopy(left) if left == right else _OMIT


def subtract_common(value: Any, common: Any):
    """Return value with shared structure removed recursively."""
    if common is _OMIT:
        return copy.deepcopy(value)

    if type(value) is not type(common):
        return copy.deepcopy(value)

    if isinstance(value, dict):
        delta = {}
        for key, item in value.items():
            if key in common:
                stripped = subtract_common(item, common[key])
                if stripped is not _OMIT:
                    delta[key] = stripped
            else:
                delta[key] = copy.deepcopy(item)
        return delta if delta else _OMIT

    if isinstance(value, list):
        if value == common:
            return _OMIT

        if value and common and all(isinstance(item, dict) for item in value + common):
            key_name = _infer_identity_key_for_dict_lists([
                [item for item in value if isinstance(item, dict)],
                [item for item in common if isinstance(item, dict)],
            ])
            if key_name:
                common_map, _ = _as_keyed_list_map(common, key_name)
                delta_items: list[Any] = []
                for item in value:
                    token = _value_key(item[key_name])
                    if token not in common_map:
                        delta_items.append(copy.deepcopy(item))
                        continue
                    stripped = subtract_common(item, common_map[token])
                    if stripped is _OMIT:
                        continue
                    if isinstance(stripped, dict) and key_name not in stripped:
                        stripped[key_name] = copy.deepcopy(item[key_name])
                    delta_items.append(stripped)
                return delta_items if delta_items else _OMIT

        return copy.deepcopy(value)

    return _OMIT if value == common else copy.deepcopy(value)


def build_shared_payload(host_payloads: list[dict[str, Any]]) -> dict[str, Any]:
    """Build one shared dictionary from all host payload dictionaries."""
    if not host_payloads:
        return {}
    shared = copy.deepcopy(host_payloads[0])
    for payload in host_payloads[1:]:
        shared = intersect_values(shared, payload)
        if shared is _OMIT:
            return {}
    if isinstance(shared, dict):
        return shared
    return {}


def build_group_shared_payload(payloads: list[dict[str, Any]]) -> dict[str, Any]:
    """Build shared payload from a subset of hosts."""
    return build_shared_payload(payloads)


def _collect_paths(value: Any, prefix: str = "") -> set[str]:
    """Collect structural dotted paths present in payload for signature grouping."""
    paths: set[str] = set()

    if isinstance(value, dict):
        for key, nested in value.items():
            if key.startswith("_merge"):
                continue
            next_prefix = f"{prefix}.{key}" if prefix else key
            paths.add(next_prefix)
            paths |= _collect_paths(nested, next_prefix)
    elif isinstance(value, list):
        list_prefix = f"{prefix}[]" if prefix else "[]"
        paths.add(list_prefix)
        for item in value:
            if isinstance(item, (dict, list)):
                paths |= _collect_paths(item, list_prefix)

    return paths


def payload_signature(payload: dict[str, Any]) -> tuple[str, ...]:
    """Build deterministic structural signature from filtered payload paths."""
    return tuple(sorted(_collect_paths(payload)))


def _collect_leaf_path_values(
    value: Any,
    prefix: tuple[str, ...] = (),
) -> dict[tuple[str, ...], Any]:
    """Collect leaf path values from nested payloads for support counting."""
    result: dict[tuple[str, ...], Any] = {}

    if isinstance(value, dict):
        for key, nested in value.items():
            if key.startswith("_merge"):
                continue
            result.update(_collect_leaf_path_values(nested, prefix + (key,)))
        return result

    if isinstance(value, list):
        if value and all(isinstance(item, dict) for item in value):
            key_name = _infer_identity_key_for_dict_lists([
                [item for item in value if isinstance(item, dict)],
            ])
            if key_name:
                for item in value:
                    key_token = _value_key(item[key_name])
                    item_prefix = prefix + (f"[{key_name}={key_token}]",)
                    result.update(_collect_leaf_path_values(item, item_prefix))
                return result

        result[prefix] = copy.deepcopy(value)
        return result

    result[prefix] = copy.deepcopy(value)
    return result


def _leaf_count(value: Any) -> int:
    """Count leaf values in nested payload for reuse scoring."""
    if isinstance(value, dict):
        return sum(_leaf_count(item) for item in value.values())
    if isinstance(value, list):
        return sum(_leaf_count(item) for item in value)
    return 1


def sanitize_group_name(name: str) -> str:
    """Normalize group names for inventory and filesystem safety."""
    sanitized = re.sub(r"[^a-zA-Z0-9_]+", "_", name.strip().lower()).strip("_")
    return sanitized or "common"


def compact_payload(value: Any):
    """Recursively remove empty dict/list branches from payloads."""
    if isinstance(value, dict):
        compacted: dict[str, Any] = {}
        for key, nested in value.items():
            cleaned = compact_payload(nested)
            if cleaned is not _OMIT:
                compacted[key] = cleaned
        return compacted if compacted else _OMIT

    if isinstance(value, list):
        compacted_list = []
        for item in value:
            cleaned = compact_payload(item)
            if cleaned is not _OMIT:
                compacted_list.append(cleaned)
        return compacted_list if compacted_list else _OMIT

    return copy.deepcopy(value)


def remove_merge_meta_keys(value: Any) -> Any:
    """Recursively remove merge and meta keys from payload math."""
    if isinstance(value, dict):
        cleaned: dict[str, Any] = {}
        for key, nested in value.items():
            if key.startswith("_merge"):
                continue
            cleaned[key] = remove_merge_meta_keys(nested)
        return cleaned
    if isinstance(value, list):
        return [remove_merge_meta_keys(item) for item in value]
    return copy.deepcopy(value)


def apply_merge_directive_hints(
    override: Any,
    baseline: Any,
    profile: str,
    list_strategy_default: str,
) -> Any:
    """Annotate override payload with merge directives according to profile."""
    if profile == "off":
        return copy.deepcopy(override)

    if isinstance(override, dict):
        hinted: dict[str, Any] = {}
        baseline_dict = baseline if isinstance(baseline, dict) else {}
        list_directives: dict[str, dict[str, str]] = {}

        for key, value in override.items():
            baseline_child = baseline_dict.get(key)
            hinted[key] = apply_merge_directive_hints(
                value,
                baseline_child,
                profile,
                list_strategy_default,
            )

            if profile in {"balanced", "aggressive"} and isinstance(value, list):
                if list_strategy_default == "append":
                    list_directives[key] = {"_merge_directive": "append"}
                elif list_strategy_default == "union":
                    list_directives[key] = {"_merge_directive": "union"}
                elif list_strategy_default == "merge_by_key_auto" and isinstance(baseline_child, list):
                    if value and baseline_child and all(
                        isinstance(item, dict) for item in (value + baseline_child)
                    ):
                        key_name = _infer_identity_key_for_dict_lists([
                            [item for item in value if isinstance(item, dict)],
                            [item for item in baseline_child if isinstance(item, dict)],
                        ])
                        if key_name:
                            list_directives[key] = {
                                "_merge_directive": "merge_by_key",
                                "_merge_key": key_name,
                            }
                    elif profile == "aggressive":
                        list_directives[key] = {"_merge_directive": "union"}

        if list_directives:
            hinted["_merge_list_directives"] = list_directives

        if isinstance(baseline, dict) and hinted:
            hinted.setdefault("_merge_directive", "merge_recursive")

        return hinted

    if isinstance(override, list):
        return [
            apply_merge_directive_hints(item, None, profile, list_strategy_default)
            for item in override
        ]

    return copy.deepcopy(override)


def parse_xml_to_payload(
    xml_file: str,
    resources: dict[str, Any],
) -> tuple[str, dict[str, Any], Optional[str]]:
    """Convert one XML config into hostname, payload, and device_type."""
    with open(xml_file) as f:
        raw = f.read()

    root = ElementTree.fromstring(f"<root>{raw}</root>")
    hostname = os.path.splitext(os.path.basename(xml_file))[0]
    hostname_elem = root.find(".//system/host-name")
    if hostname_elem is not None and hostname_elem.text:
        hostname = hostname_elem.text
    config = root.find(".//configuration")
    if config is None:
        raise ValueError(f"No <configuration> found in {xml_file}")

    xml_dict = elem_to_dict(config, "", resources["root"])
    return hostname, xml_dict, detect_device_type(xml_dict)


def write_yaml_file(output_path: str, payload: dict[str, Any]) -> None:
    """Write YAML payload to disk preserving key order."""
    yaml_output = yaml.dump(payload, sort_keys=False)
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    with open(output_path, "w") as f:
        f.write(yaml_output)


def load_yaml_file(input_path: str) -> dict[str, Any]:
    """Load a YAML mapping file and return an empty dict when missing or empty."""
    if not os.path.exists(input_path):
        return {}
    with open(input_path, "r") as f:
        data = yaml.safe_load(f) or {}
    return data if isinstance(data, dict) else {}


def load_host_payload_cache(directory: str) -> dict[str, dict[str, Any]]:
    """Load cached host payloads from output directory."""
    cache_path = os.path.join(directory, HOST_PAYLOAD_CACHE_FILE)
    if not os.path.exists(cache_path):
        return {}

    try:
        with open(cache_path, "r") as f:
            raw = json.load(f)
    except (OSError, ValueError, json.JSONDecodeError):
        return {}

    if not isinstance(raw, dict):
        return {}

    return {
        str(hostname): remove_merge_meta_keys(payload)
        for hostname, payload in raw.items()
        if isinstance(payload, dict)
    }


def write_host_payload_cache(directory: str, payload_by_host: dict[str, dict[str, Any]]) -> None:
    """Persist cached host payloads for multi-run global baseline computation."""
    cache_path = os.path.join(directory, HOST_PAYLOAD_CACHE_FILE)
    with open(cache_path, "w") as f:
        json.dump(payload_by_host, f, indent=2, sort_keys=True)


def deep_merge_dicts(base: dict[str, Any], override: dict[str, Any]) -> dict[str, Any]:
    """Deep merge two dictionaries with override precedence."""
    merged = copy.deepcopy(base)
    for key, value in override.items():
        if (
            key in merged
            and isinstance(merged[key], dict)
            and isinstance(value, dict)
        ):
            merged[key] = deep_merge_dicts(merged[key], value)
        else:
            merged[key] = copy.deepcopy(value)
    return merged


def load_schema(trimmed_json_file: str) -> dict[str, Any]:
    """Load and validate trimmed schema content."""
    with open(trimmed_json_file, "r") as f:
        schema = json.load(f)

    has_configuration = any(
        child.get("name") == "configuration"
        for child in schema.get("root", {}).get("children", [])
    )
    if not has_configuration:
        raise ValueError("No configuration node found in JSON schema")
    return schema


def parse_host_entries(
    xml_files: list[str],
    schema: dict[str, Any],
) -> list[tuple[str, dict[str, Any], Optional[str]]]:
    """Parse XML input files into normalized host entry tuples."""
    return [parse_xml_to_payload(xml_file, schema) for xml_file in xml_files]


def derive_host_delta_entries(
    full_payload_by_host: dict[str, dict[str, Any]],
    global_shared_payload: dict[str, Any],
) -> list[tuple[str, dict[str, Any]]]:
    """Build host payload deltas relative to shared all.yaml payload."""
    entries: list[tuple[str, dict[str, Any]]] = []
    for hostname in sorted(full_payload_by_host.keys()):
        delta = subtract_common(full_payload_by_host[hostname], global_shared_payload)
        if delta is _OMIT or not isinstance(delta, dict):
            delta = {}
        entries.append((hostname, delta))
    return entries


def _build_children_by_parent(parent_map: dict[str, Optional[str]]) -> dict[Optional[str], list[str]]:
    children: dict[Optional[str], list[str]] = {}
    for group_name, parent in parent_map.items():
        children.setdefault(parent, []).append(group_name)
    return children


def build_group_full_payloads(
    common_groups: dict[str, list[str]],
    payload_by_hostname: dict[str, dict[str, Any]],
) -> dict[str, dict[str, Any]]:
    """Build full payloads for groups from member host intersections."""
    full_payloads: dict[str, dict[str, Any]] = {}
    for group_name, members in common_groups.items():
        payloads = [payload_by_hostname[member] for member in members if member in payload_by_hostname]
        full_payloads[group_name] = build_group_shared_payload(payloads)
    return full_payloads


def build_group_path_map(parent_map: dict[str, Optional[str]]) -> dict[str, str]:
    """Map group names to flat directory paths under group_vars/."""
    return {group_name: _plain_group_name(group_name) for group_name in parent_map.keys()}


def ancestor_chain(group_name: str, parent_map: dict[str, Optional[str]]) -> list[str]:
    """Return ancestor chain from root group to the provided group."""
    chain: list[str] = []
    current: Optional[str] = group_name
    while current is not None:
        chain.append(current)
        current = parent_map.get(current)
    chain.reverse()
    return chain


def assign_leaf_group_per_host(
    common_groups: dict[str, list[str]],
    parent_map: dict[str, Optional[str]],
) -> dict[str, str]:
    """Assign each host to one deterministic deepest group."""
    children_by_parent = _build_children_by_parent(parent_map)
    leaves = [name for name in common_groups.keys() if not children_by_parent.get(name)]
    leaf_members = {name: set(common_groups[name]) for name in leaves}

    host_to_leaf: dict[str, str] = {}
    all_hosts = sorted({host for hosts in common_groups.values() for host in hosts})
    for host in all_hosts:
        candidates = [name for name, members in leaf_members.items() if host in members]
        if not candidates:
            candidates = [name for name, members in common_groups.items() if host in members]
        if not candidates:
            continue
        candidates.sort(key=lambda name: (len(common_groups[name]), name))
        host_to_leaf[host] = candidates[0]
    return host_to_leaf


def _set_path(payload: dict[str, Any], path: tuple[str, ...], value: Any) -> None:
    cursor = payload
    for segment in path[:-1]:
        if segment not in cursor or not isinstance(cursor[segment], dict):
            cursor[segment] = {}
        cursor = cursor[segment]
    cursor[path[-1]] = copy.deepcopy(value)


def _delete_path(payload: dict[str, Any], path: tuple[str, ...]) -> None:
    if not path:
        return

    cursor: Any = payload
    stack: list[tuple[dict[str, Any], str]] = []
    for segment in path:
        if not isinstance(cursor, dict) or segment not in cursor:
            return
        stack.append((cursor, segment))
        cursor = cursor[segment]

    parent, leaf = stack[-1]
    del parent[leaf]
    for node, key in reversed(stack[:-1]):
        child = node.get(key)
        if isinstance(child, dict) and not child:
            del node[key]
        else:
            break


def detect_and_fallback_sibling_conflicts(
    common_groups: dict[str, list[str]],
    parent_map: dict[str, Optional[str]],
    group_full_payloads: dict[str, dict[str, Any]],
    payload_by_hostname: dict[str, dict[str, Any]],
) -> dict[str, dict[str, Any]]:
    """Move unresolved sibling conflicts into host-specific fallback payloads."""
    host_fallbacks: dict[str, dict[str, Any]] = {}
    children_by_parent = _build_children_by_parent(parent_map)

    for _parent, siblings in children_by_parent.items():
        if len(siblings) < 2:
            continue
        ordered_siblings = sorted(siblings)
        for index, left in enumerate(ordered_siblings):
            for right in ordered_siblings[index + 1:]:
                overlap_hosts = set(common_groups[left]) & set(common_groups[right])
                if not overlap_hosts:
                    continue

                left_paths = _collect_leaf_path_values(group_full_payloads.get(left, {}))
                right_paths = _collect_leaf_path_values(group_full_payloads.get(right, {}))
                shared_paths = set(left_paths.keys()) & set(right_paths.keys())

                for path in sorted(shared_paths):
                    if _value_key(left_paths[path]) == _value_key(right_paths[path]):
                        continue
                    for host in sorted(overlap_hosts):
                        host_values = _collect_leaf_path_values(payload_by_hostname.get(host, {}))
                        if path not in host_values:
                            continue
                        host_fallbacks.setdefault(host, {})
                        _set_path(host_fallbacks[host], path, host_values[path])
                    _delete_path(group_full_payloads[left], path)
                    _delete_path(group_full_payloads[right], path)

    return host_fallbacks


def build_group_delta_payloads(
    parent_map: dict[str, Optional[str]],
    group_full_payloads: dict[str, dict[str, Any]],
    merge_profile: str,
    list_strategy_default: str,
) -> dict[str, dict[str, Any]]:
    """Compute strict deltas for groups against parent ancestry payloads."""
    group_deltas: dict[str, dict[str, Any]] = {}
    ordered_names = sorted(
        parent_map.keys(),
        key=lambda name: (len(ancestor_chain(name, parent_map)), name),
    )
    for group_name in ordered_names:
        parent = parent_map[group_name]
        baseline = group_full_payloads.get(parent, {}) if parent is not None else {}
        delta = subtract_common(group_full_payloads.get(group_name, {}), baseline)
        if delta is _OMIT:
            payload: dict[str, Any] = {}
        else:
            compacted = compact_payload(delta)
            payload = compacted if isinstance(compacted, dict) else {}
        group_deltas[group_name] = apply_merge_directive_hints(
            payload,
            baseline,
            merge_profile,
            list_strategy_default,
        ) if merge_profile != "off" else payload
    return group_deltas


def write_group_hierarchy_payloads(
    group_vars_root: str,
    parent_map: dict[str, Optional[str]],
    group_delta_payloads: dict[str, dict[str, Any]],
) -> dict[str, str]:
    """Write group hierarchy directories with all.yaml payload files."""
    path_map = build_group_path_map(parent_map)
    for group_name in sorted(path_map.keys(), key=lambda name: path_map[name]):
        output_path = os.path.join(group_vars_root, path_map[group_name], ALL_YAML)
        write_yaml_file(output_path, group_delta_payloads.get(group_name, {}))
    return path_map


def rewrite_host_vars_with_hierarchy(
    host_entries: list[tuple[str, dict[str, Any], Optional[str]]],
    host_vars_root: str,
    global_payload: dict[str, Any],
    parent_map: dict[str, Optional[str]],
    group_full_payloads: dict[str, dict[str, Any]],
    host_to_leaf_group: dict[str, str],
    host_fallback_overrides: dict[str, dict[str, Any]],
    merge_profile: str,
    list_strategy_default: str,
) -> None:
    """Rewrite host_vars as strict deltas against global plus hierarchy baseline."""
    for hostname, full_payload, _detected_type in host_entries:
        baseline = copy.deepcopy(global_payload)
        leaf_group = host_to_leaf_group.get(hostname)
        if leaf_group:
            for group_name in ancestor_chain(leaf_group, parent_map):
                baseline = deep_merge_dicts(baseline, group_full_payloads.get(group_name, {}))

        fallback_payload = host_fallback_overrides.get(hostname, {})
        if fallback_payload:
            baseline = deep_merge_dicts(baseline, fallback_payload)

        delta = subtract_common(full_payload, baseline)
        if delta is _OMIT:
            payload: dict[str, Any] = {}
        else:
            compacted = compact_payload(delta)
            payload = compacted if isinstance(compacted, dict) else {}

        hinted = apply_merge_directive_hints(
            payload,
            baseline,
            merge_profile,
            list_strategy_default,
        ) if merge_profile != "off" else payload
        write_yaml_file(os.path.join(host_vars_root, f"{hostname}.yaml"), hinted)


def inventory_group_sort_key(name: str) -> tuple[int, int, str]:
    """Sort inventory groups lexicographically by name."""
    return (0, 0, name)


def load_inventory_sections(inventory_path: str) -> dict[str, Any]:
    """Load inventory into all, host-group, and children-group sections."""
    result = {"all": [], "hosts": {}, "children": {}}
    if not os.path.exists(inventory_path):
        return result

    current_name: Optional[str] = None
    current_kind: Optional[str] = None
    with open(inventory_path, "r") as f:
        for line in f:
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue
            if stripped.startswith("[") and stripped.endswith("]"):
                section = stripped[1:-1]
                if section == "all":
                    current_name = "all"
                    current_kind = "all"
                elif section.endswith(":children"):
                    current_name = section[:-9]
                    current_kind = "children"
                    result["children"].setdefault(current_name, [])
                else:
                    current_name = section
                    current_kind = "hosts"
                    result["hosts"].setdefault(current_name, [])
                continue

            if current_kind == "all":
                result["all"].append(stripped.split()[0])
            elif current_kind == "hosts" and current_name:
                result["hosts"][current_name].append(stripped.split()[0])
            elif current_kind == "children" and current_name:
                result["children"][current_name].append(stripped)

    return result


