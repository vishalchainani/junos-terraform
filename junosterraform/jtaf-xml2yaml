def _parse_grouping_hosts_file(grouping_hosts_file: str) -> tuple[dict[str, Any], list[str]]:
    """Parse grouping.hosts file and return parse errors with line context."""
    result = {"all": [], "hosts": {}, "children": {}}
    errors: list[str] = []

    if not os.path.exists(grouping_hosts_file):
        return result, [f"{grouping_hosts_file}: file does not exist"]
    if not os.path.isfile(grouping_hosts_file):
        return result, [f"{grouping_hosts_file}: not a regular file"]

    current_name: Optional[str] = None
    current_kind: Optional[str] = None
    seen_sections: set[str] = set()

    with open(grouping_hosts_file, "r") as f:
        for line_no, line in enumerate(f, start=1):
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue

            if stripped.startswith("[") or stripped.endswith("]"):
                if not (stripped.startswith("[") and stripped.endswith("]")):
                    errors.append(f"line {line_no}: malformed section header: {stripped}")
                    current_name = None
                    current_kind = None
                    continue

                section = stripped[1:-1].strip()
                if not section:
                    errors.append(f"line {line_no}: empty section header")
                    current_name = None
                    current_kind = None
                    continue

                if section in seen_sections:
                    errors.append(f"line {line_no}: duplicate section [{section}]")
                seen_sections.add(section)

                if section == "all":
                    current_name = "all"
                    current_kind = "all"
                elif section.endswith(":children"):
                    group_name = section[:-9].strip()
                    if not group_name:
                        errors.append(f"line {line_no}: invalid children section name [{section}]")
                        current_name = None
                        current_kind = None
                        continue
                    current_name = group_name
                    current_kind = "children"
                    result["children"].setdefault(current_name, [])
                else:
                    current_name = section
                    current_kind = "hosts"
                    result["hosts"].setdefault(current_name, [])
                continue

            if current_kind is None:
                errors.append(f"line {line_no}: entry outside section: {stripped}")
                continue

            token = stripped.split()[0]
            if current_kind == "all":
                result["all"].append(token)
            elif current_kind == "hosts" and current_name:
                result["hosts"][current_name].append(token)
            elif current_kind == "children" and current_name:
                result["children"][current_name].append(token)

    return result, errors


def _detect_group_cycle(children_map: dict[str, list[str]]) -> Optional[list[str]]:
    """Return one cycle path if hierarchy contains a cycle."""
    visited: set[str] = set()
    in_stack: set[str] = set()
    path: list[str] = []

    def dfs(node: str) -> Optional[list[str]]:
        visited.add(node)
        in_stack.add(node)
        path.append(node)

        for child in children_map.get(node, []):
            if child not in visited:
                cycle = dfs(child)
                if cycle:
                    return cycle
            elif child in in_stack:
                cycle_start = path.index(child)
                return path[cycle_start:] + [child]

        path.pop()
        in_stack.remove(node)
        return None

    all_groups = set(children_map.keys())
    for children in children_map.values():
        all_groups.update(children)

    for node in sorted(all_groups):
        if node in visited:
            continue
        cycle = dfs(node)
        if cycle:
            return cycle
    return None


def _build_user_groups_from_inventory(
    parsed_inventory: dict[str, Any],
    active_hostnames: list[str],
    strict_known_hosts: bool,
) -> tuple[dict[str, list[str]], dict[str, Optional[str]], dict[str, str], list[str]]:
    """Build user-defined group memberships, parent map, and host leaf assignment."""
    errors: list[str] = []
    active_set = set(active_hostnames)

    hosts_map: dict[str, list[str]] = {
        name: list(dict.fromkeys(hosts))
        for name, hosts in parsed_inventory.get("hosts", {}).items()
        if name != "all"
    }
    children_map: dict[str, list[str]] = {
        name: list(dict.fromkeys(children))
        for name, children in parsed_inventory.get("children", {}).items()
    }

    defined_groups = set(hosts_map.keys()) | set(children_map.keys())
    for _parent, children in children_map.items():
        for child in children:
            if child not in defined_groups:
                errors.append(f"undefined child group reference: '{child}'")

    cycle = _detect_group_cycle(children_map)
    if cycle:
        errors.append("group hierarchy cycle detected: " + " -> ".join(cycle))

    parent_of: dict[str, str] = {}
    for parent, children in children_map.items():
        for child in children:
            existing = parent_of.get(child)
            if existing is not None and existing != parent:
                errors.append(f"group '{child}' has multiple parents: '{existing}' and '{parent}'")
            else:
                parent_of[child] = parent

    if strict_known_hosts:
        for group_name, hosts in hosts_map.items():
            unknown = sorted(set(hosts) - active_set)
            for host in unknown:
                errors.append(f"group '{group_name}' references unknown host '{host}'")

    common_groups: dict[str, list[str]] = {}

    def resolve_members(group_name: str, stack: Optional[set[str]] = None) -> set[str]:
        if group_name in common_groups:
            return set(common_groups[group_name])

        local_stack = set() if stack is None else set(stack)
        if group_name in local_stack:
            return set()
        local_stack.add(group_name)

        members = set(hosts_map.get(group_name, []))
        for child in children_map.get(group_name, []):
            members |= resolve_members(child, local_stack)

        members &= active_set
        common_groups[group_name] = sorted(members)
        return members

    for group_name in sorted(defined_groups):
        resolve_members(group_name)

    common_groups = {
        group_name: members
        for group_name, members in common_groups.items()
        if members
    }

    parent_map: dict[str, Optional[str]] = {}
    for group_name in common_groups.keys():
        parent = parent_of.get(group_name)
        while parent is not None and parent not in common_groups:
            parent = parent_of.get(parent)
        parent_map[group_name] = parent

    # When users provide only host membership groups (no :children sections),
    # infer a stable hierarchy from strict host-set containment.
    for group_name in sorted(common_groups.keys()):
        if parent_map.get(group_name) is not None:
            continue
        group_hosts = set(common_groups.get(group_name, []))
        if not group_hosts:
            continue

        candidates = [
            other_name
            for other_name, other_hosts in common_groups.items()
            if other_name != group_name
            and group_hosts < set(other_hosts)
        ]
        if not candidates:
            continue

        candidates.sort(key=lambda name: (len(common_groups.get(name, [])), name))
        parent_map[group_name] = candidates[0]

    children_by_parent = _build_children_by_parent(parent_map)
    leaves = [name for name in common_groups.keys() if not children_by_parent.get(name)]
    host_to_leaf: dict[str, str] = {}
    for host in active_hostnames:
        candidates = [name for name in leaves if host in set(common_groups.get(name, []))]
        if not candidates:
            candidates = [name for name, members in common_groups.items() if host in set(members)]
        if not candidates:
            errors.append(f"host '{host}' is not part of any defined group")
            continue
        candidates.sort(key=lambda name: (len(ancestor_chain(name, parent_map)), name), reverse=True)
        host_to_leaf[host] = candidates[0]

    return common_groups, parent_map, host_to_leaf, errors


def resolve_grouping_hosts_file_path(args: argparse.Namespace) -> str:
    """Resolve grouping.hosts path from args or optional interactive fallback."""
    if args.grouping_hosts_file:
        return args.grouping_hosts_file

    if not args.interactive:
        raise SystemExit(
            "Missing required --grouping-hosts-file. "
            "Use --grouping-hosts-file <path> or --interactive for prompt fallback."
        )

    print("Sample grouping.hosts format:\n")
    print(GROUPING_HOSTS_SAMPLE)
    while True:
        candidate = input("Enter path to grouping.hosts: ").strip()
        if candidate:
            return candidate
        print("Path cannot be empty.")


def build_hierarchical_inventory_groups(
    parent_map: dict[str, Optional[str]],
    host_to_leaf_group: dict[str, str],
) -> dict[str, Any]:
    """Build inventory sections for host memberships and parent-child links."""
    children_by_parent: dict[str, list[str]] = {}
    for group_name, parent in parent_map.items():
        if parent is None:
            continue
        parent_name = _plain_group_name(parent)
        child_name = _plain_group_name(group_name)
        children_by_parent.setdefault(parent_name, []).append(child_name)

    hosts_by_group: dict[str, list[str]] = {}
    for host, group_name in host_to_leaf_group.items():
        for ancestor in ancestor_chain(group_name, parent_map):
            key = _plain_group_name(ancestor)
            hosts_by_group.setdefault(key, []).append(host)

    for key in list(children_by_parent.keys()):
        children_by_parent[key] = sorted(set(children_by_parent[key]))
    for key in list(hosts_by_group.keys()):
        hosts_by_group[key] = sorted(set(hosts_by_group[key]))

    return {"hosts": hosts_by_group, "children": children_by_parent}


def reconstruct_hierarchy_from_inventory(
    inventory_sections: dict[str, Any],
    known_hosts: list[str],
) -> tuple[dict[str, Optional[str]], dict[str, str]]:
    """Reconstruct parent map and host->leaf assignments from inventory sections."""
    host_groups = inventory_sections.get("hosts", {}) if isinstance(inventory_sections, dict) else {}
    children_groups = inventory_sections.get("children", {}) if isinstance(inventory_sections, dict) else {}

    parent_map: dict[str, Optional[str]] = {
        str(group_name): None
        for group_name in host_groups.keys()
    }
    for parent_name, children in children_groups.items():
        parent = str(parent_name)
        parent_map.setdefault(parent, None)
        if not isinstance(children, list):
            continue
        for child_name in children:
            child = str(child_name)
            parent_map[child] = parent

    children_by_parent = _build_children_by_parent(parent_map)
    leaves = [group_name for group_name in parent_map.keys() if not children_by_parent.get(group_name)]

    known_host_set = set(known_hosts)
    host_to_leaf: dict[str, str] = {}
    for hostname in sorted(known_host_set):
        candidates = [
            leaf
            for leaf in leaves
            if hostname in set(host_groups.get(leaf, []))
        ]
        if not candidates:
            continue
        candidates.sort(
            key=lambda name: (len(ancestor_chain(name, parent_map)), name),
            reverse=True,
        )
        host_to_leaf[hostname] = candidates[0]

    return parent_map, host_to_leaf


def write_inventory(
    hosts_file: str,
    active_hostnames: list[str],
    inventory_groups: dict[str, Any],
    owned_group_names: list[str],
) -> None:
    """Write or update inventory while preserving unrelated provider sections."""
    existing = load_inventory_sections(hosts_file)
    owned = set(owned_group_names)

    merged_all_hosts = sorted(set(existing.get("all", [])) | set(active_hostnames))
    merged_host_groups = {
        name: hosts
        for name, hosts in existing.get("hosts", {}).items()
        if name not in owned
    }
    merged_children_groups = {
        name: children
        for name, children in existing.get("children", {}).items()
        if name not in owned
    }

    for group_name, hosts in inventory_groups.get("hosts", {}).items():
        merged_host_groups[group_name] = sorted(set(hosts))
    for group_name, children in inventory_groups.get("children", {}).items():
        merged_children_groups[group_name] = sorted(set(children))

    with open(hosts_file, "w") as f:
        f.write("[all]\n")
        for hostname in merged_all_hosts:
            f.write(f"{hostname}\n")

        for group_name in merged_host_groups.keys():
            f.write(f"\n[{group_name}]\n")
            for hostname in merged_host_groups[group_name]:
                f.write(f"{hostname}\n")

        for group_name in merged_children_groups.keys():
            f.write(f"\n[{group_name}:children]\n")
            for child_name in merged_children_groups[group_name]:
                f.write(f"{child_name}\n")


def clear_target_group_dirs(
    group_vars_root: str,
    parent_map: dict[str, Optional[str]],
) -> None:
    """Remove only group subdirectories targeted by the current run."""
    if not os.path.isdir(group_vars_root):
        return

    target_paths = sorted(set(build_group_path_map(parent_map).values()))
    for relative_path in target_paths:
        entry_path = os.path.join(group_vars_root, relative_path)
        if os.path.isdir(entry_path):
            shutil.rmtree(entry_path)


def main() -> None:
    """Generate generic hierarchical group_vars/host_vars and inventory from XML."""
    parser = argparse.ArgumentParser(
        description="Generate Ansible hosts and hierarchical group_vars/host_vars from XML using trimmed schema.",
        exit_on_error=True,
    )
    parser.add_argument(
        "-j",
        "--trimmed_json",
        required=True,
        help="Path to trimmed_schema.json generated by jtaf-provider/jtaf-yang2go.",
    )
    parser.add_argument(
        "-x",
        "--xml-config",
        required=True,
        nargs="+",
        help="One or more Junos XML config files to convert into host_vars YAML.",
    )
    parser.add_argument(
        "-d",
        "--directory",
        required=True,
        help="Output directory for hosts file and host_vars/*.yaml.",
    )
    parser.add_argument(
        "--hosts-file",
        default=None,
        help="Optional path to inventory hosts file. Defaults to <directory>/hosts.",
    )
    parser.add_argument(
        "--host-vars-dir",
        default=None,
        help="Optional host_vars directory. Defaults to <directory>/host_vars.",
    )
    parser.add_argument(
        "--group-vars-dir",
        default=None,
        help="Optional group_vars directory. Defaults to <directory>/group_vars.",
    )
    parser.add_argument(
        "--grouping-hosts-file",
        default=None,
        help="Path to user-defined grouping.hosts file. Required unless --interactive is used.",
    )
    parser.add_argument(
        "--interactive",
        action="store_true",
        default=False,
        help="Optional prompt fallback to enter grouping.hosts path.",
    )
    parser.add_argument(
        "--strict-grouping-known-hosts",
        action="store_true",
        default=False,
        help="Fail when grouping.hosts references hosts not present in current XML input set.",
    )
    parser.add_argument(
        "--merge-directive-profile",
        choices=["off", "minimal", "balanced", "aggressive"],
        default="balanced",
    )
    parser.add_argument(
        "--merge-list-strategy-default",
        choices=["replace", "union", "append", "merge_by_key_auto"],
        default="merge_by_key_auto",
    )
    args = parser.parse_args()

    schema = load_schema(args.trimmed_json)

    directory = args.directory
    hosts_file = args.hosts_file or os.path.join(directory, "hosts")
    host_vars_dir = args.host_vars_dir or os.path.join(directory, "host_vars")
    group_vars_dir = args.group_vars_dir or os.path.join(directory, "group_vars")

    os.makedirs(os.path.dirname(hosts_file) or ".", exist_ok=True)
    os.makedirs(host_vars_dir, exist_ok=True)
    os.makedirs(group_vars_dir, exist_ok=True)

    host_entries = parse_host_entries(args.xml_config, schema)
    full_payload_by_host = {
        hostname: remove_merge_meta_keys(payload)
        for hostname, payload, _device_type in host_entries
    }
    active_hostnames = sorted(full_payload_by_host.keys())
    cached_payload_by_host = load_host_payload_cache(directory)
    cached_payload_by_host.update(full_payload_by_host)
    all_hostnames = sorted(cached_payload_by_host.keys())

    grouping_hosts_file = resolve_grouping_hosts_file_path(args)
    parsed_inventory, parse_errors = _parse_grouping_hosts_file(grouping_hosts_file)
    if parse_errors:
        raise SystemExit("grouping.hosts parsing failed:\n- " + "\n- ".join(parse_errors))

    current_run_shared_payload = build_shared_payload(
        [cached_payload_by_host[hostname] for hostname in all_hostnames]
    )
    all_yaml_path = os.path.join(group_vars_dir, ALL_YAML)
    global_shared_payload = current_run_shared_payload
    active_host_delta_entries = derive_host_delta_entries(full_payload_by_host, global_shared_payload)
    payload_by_hostname = {hostname: payload for hostname, payload in active_host_delta_entries}

    common_groups, parent_map, host_to_leaf_group, grouping_errors = _build_user_groups_from_inventory(
        parsed_inventory,
        active_hostnames,
        strict_known_hosts=args.strict_grouping_known_hosts,
    )
    if grouping_errors:
        raise SystemExit("grouping.hosts validation failed:\n- " + "\n- ".join(grouping_errors))

    existing_inventory = load_inventory_sections(hosts_file)
    existing_parent_map, existing_host_to_leaf = reconstruct_hierarchy_from_inventory(
        existing_inventory,
        all_hostnames,
    )

    merged_parent_map = dict(existing_parent_map)
    for group_name, parent_name in parent_map.items():
        merged_parent_map[group_name] = parent_name
    for group_name in merged_parent_map.keys():
        merged_parent_map.setdefault(group_name, None)

    merged_host_to_leaf = dict(existing_host_to_leaf)
    for hostname, leaf_group in host_to_leaf_group.items():
        merged_host_to_leaf[hostname] = leaf_group
    merged_host_to_leaf = {
        hostname: leaf_group
        for hostname, leaf_group in merged_host_to_leaf.items()
        if hostname in set(all_hostnames) and leaf_group in merged_parent_map
    }

    inventory_groups_all = build_hierarchical_inventory_groups(merged_parent_map, merged_host_to_leaf)

    all_host_delta_entries = derive_host_delta_entries(cached_payload_by_host, global_shared_payload)
    payload_by_hostname_all = {hostname: payload for hostname, payload in all_host_delta_entries}
    common_groups_all = {
        group_name: members
        for group_name, members in inventory_groups_all.get("hosts", {}).items()
        if members
    }
    effective_parent_map: dict[str, Optional[str]] = {}
    for group_name, parent_name in merged_parent_map.items():
        if group_name not in common_groups_all:
            continue
        parent = parent_name
        while parent is not None and parent not in common_groups_all:
            parent = merged_parent_map.get(parent)
        effective_parent_map[group_name] = parent

    group_full_payloads = build_group_full_payloads(common_groups_all, payload_by_hostname_all)
    host_fallback_overrides = detect_and_fallback_sibling_conflicts(
        common_groups_all,
        effective_parent_map,
        group_full_payloads,
        payload_by_hostname_all,
    )

    group_delta_payloads = build_group_delta_payloads(
        effective_parent_map,
        group_full_payloads,
        args.merge_directive_profile,
        args.merge_list_strategy_default,
    )

    clear_target_group_dirs(group_vars_dir, effective_parent_map)
    global_with_hints = apply_merge_directive_hints(
        global_shared_payload,
        {},
        args.merge_directive_profile,
        args.merge_list_strategy_default,
    ) if args.merge_directive_profile != "off" else global_shared_payload
    write_yaml_file(all_yaml_path, global_with_hints)
    write_group_hierarchy_payloads(group_vars_dir, effective_parent_map, group_delta_payloads)
    write_host_payload_cache(directory, cached_payload_by_host)

    host_entries_all = [
        (hostname, cached_payload_by_host[hostname], None)
        for hostname in sorted(cached_payload_by_host.keys())
    ]

    rewrite_host_vars_with_hierarchy(
        host_entries_all,
        host_vars_dir,
        global_shared_payload,
        effective_parent_map,
        group_full_payloads,
        merged_host_to_leaf,
        host_fallback_overrides,
        args.merge_directive_profile,
        args.merge_list_strategy_default,
    )

    owned_group_names = sorted(
        set(inventory_groups_all.get("hosts", {}).keys())
        | set(inventory_groups_all.get("children", {}).keys())
    )
    write_inventory(hosts_file, all_hostnames, inventory_groups_all, owned_group_names)


